generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("admin") // admin, barber, customer
  phone     String?
  avatar    String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  resetPasswordToken   String?   @unique
  resetPasswordExpires DateTime?

  // ✅ CAMPOS DE ACEITAÇÃO DE TERMOS (LGPD) - BARBEIROS
  termsAccepted      Boolean   @default(false)
  termsAcceptedAt    DateTime?
  privacyAccepted    Boolean   @default(false)
  privacyAcceptedAt  DateTime?
  termsVersion       String?
  privacyVersion     String?

  preferences Json? @default("{\"emailNotifications\":true,\"smsNotifications\":false,\"whatsappNotifications\":true,\"theme\":\"light\"}")

  commissionPercentage Float @default(40)

  tutorialCompleted Boolean @default(false)
  tutorialStep      Int?    @default(0)
  tutorialSkipped   Boolean @default(false)

  barbershop   Barbershop? @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  barbershopId String?

  appointments     Appointment[]
  servicesProvided Service[]
  commissions      Commission[]
  transactions     Transaction[]  @relation("BarberTransactions")
  packageUsages    PackageUsage[] @relation("BarberPackageUsages")
  stockMovements   StockMovement[] @relation("BarberStockMovements")

  // ✅ B1: Índice composto [barbershopId, role]
  // Cobre: { barbershopId } (listagem), { barbershopId, role: 'barber' } (barbeiros ativos),
  // { barbershopId, role: 'barber', active: true } (dashboard, analytics, commissions)
  @@index([barbershopId, role])
  @@map("users")
}

model Barbershop {
  id          String    @id @default(uuid())
  name        String
  slug        String?   @unique
  email       String    @unique
  phone       String
  address     String?
  city        String?
  state       String?
  logo        String?
  plan        String    @default("trial")
  planStatus  String    @default("active")
  trialEndsAt DateTime?
  planStartedAt DateTime @default(now())
  planExpiresAt DateTime?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  maxBarbers   Int @default(1)
  maxCustomers Int @default(100)

  zipCode     String?
  cnpj        String?
  description String? @db.Text

  heroImage         String?
  heroTitle         String?
  heroSubtitle      String?
  galleryImages     String[] @default([])
  businessHours     Json?
  instagramUrl      String?
  facebookUrl       String?
  whatsappNumber    String?
  youtubeUrl        String?
  primaryColor      String?  @default("#2563eb")
  secondaryColor    String?  @default("#7c3aed")
  showTeam          Boolean  @default(true)
  showGallery       Boolean  @default(true)
  showReviews       Boolean  @default(true)
  allowOnlineBooking Boolean @default(true)

  neighborhood String?
  number       String?
  complement   String?
  latitude     Float?
  longitude    Float?

  users            User[]
  services         Service[]
  appointments     Appointment[]
  customers        Customer[]
  subscriptions    Subscription[]
  transactions     Transaction[]
  commissions      Commission[]
  goals            Goal[]
  clientFavorites  ClientFavorite[]
  // ✅ NOVO
  stockItems       StockItem[]
  customerPackages CustomerPackage[]

  // ✅ B1: Índice composto [planStatus, active]
  // Cobre: public-barbershop.routes.ts { active: true, planStatus: 'active' }
  // Cobre: update-plan-status.job.ts updateMany { planStatus: { not: 'expired' } }
  // e { planStatus: 'active', planExpiresAt: { lt: now } }
  @@index([planStatus, active])
  @@map("barbershops")
}

model Transaction {
  id            String   @id @default(uuid())
  barbershopId  String
  type          String
  category      String
  description   String
  amount        Decimal  @db.Decimal(10, 2)
  date          DateTime
  paymentMethod String?
  status        String   @default("completed")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  barberId    String?
  customerId  String?
  serviceName String?

  barbershop Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  barber     User?      @relation("BarberTransactions", fields: [barberId], references: [id], onDelete: SetNull)
  customer   Customer?  @relation("CustomerTransactions", fields: [customerId], references: [id], onDelete: SetNull)

  // ✅ B1: Índice composto [barbershopId, date]
  // Cobre: { barbershopId } simples (prefixo esquerdo)
  // Cobre: { barbershopId, date: { gte, lte } } — Finance/cashflow, Finance/summary,
  //        Finance/DRE, dashboard/charts 12 meses, analytics 30 dias
  // Nota: type e status NÃO foram indexados separadamente porque 100% das queries
  //       de Transaction incluem um filtro de date, tornando o índice de date suficiente.
  @@index([barbershopId, date])
  @@map("transactions")
}

model Commission {
  id             String    @id @default(uuid())
  barberId       String
  barbershopId   String
  percentage     Float
  amount         Decimal   @db.Decimal(10, 2)
  referenceMonth DateTime
  status         String    @default("pending")
  paidAt         DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  barber     User       @relation(fields: [barberId], references: [id], onDelete: Cascade)
  barbershop Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)

  // ✅ B1: Índice composto [barbershopId, barberId]
  // barbershopId como coluna LÍDER cobre:
  //   - { barbershopId } → listagem de comissões da barbearia
  //   - { barbershopId, barberId } → cálculo por barbeiro (loop)
  //   - { barbershopId, barberId, referenceMonth } → verificação de mês já calculado
  // Um único índice substitui dois índices separados ([barbershopId] + [barberId, barbershopId])
  @@index([barbershopId, barberId])
  @@map("commissions")
}

model Goal {
  id            String   @id @default(uuid())
  barbershopId  String
  name          String
  targetAmount  Decimal  @db.Decimal(10, 2)
  currentAmount Decimal  @db.Decimal(10, 2) @default(0)
  startDate     DateTime
  endDate       DateTime
  status        String   @default("active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  barbershop Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)

  // ✅ B1: Índice simples [barbershopId]
  // Tabela de baixo volume — simples é suficiente
  @@index([barbershopId])
  @@map("goals")
}

model Subscription {
  id                 String    @id @default(uuid())
  barbershopId       String
  plan               String
  status             String    @default("active")
  amount             Decimal   @db.Decimal(10, 2)
  paymentMethod      String?
  externalId         String?
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelledAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  barbershop Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  payments   Payment[]

  @@map("subscriptions")
}

model Payment {
  id             String    @id @default(uuid())
  subscriptionId String
  amount         Decimal   @db.Decimal(10, 2)
  status         String    @default("pending")
  paymentMethod  String
  externalId     String?
  paidAt         DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Service {
  id           String   @id @default(uuid())
  name         String
  description  String?
  price        Decimal  @db.Decimal(10, 2)
  duration     Int
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  barbershop   Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  barbershopId String

  barber   User?   @relation(fields: [barberId], references: [id], onDelete: SetNull)
  barberId String?

  appointments Appointment[]

  // ✅ B1: Índice composto [barbershopId, active]
  // Cobre: { barbershopId } simples (prefixo esquerdo)
  // Cobre: { barbershopId, active: true } — dashboard count, GET /services com filtro
  @@index([barbershopId, active])
  @@map("services")
}

model Customer {
  id        String    @id @default(uuid())
  name      String
  email     String?
  phone     String
  birthDate DateTime?
  notes     String?
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  barbershop   Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  barbershopId String

  appointments     Appointment[]
  transactions     Transaction[]    @relation("CustomerTransactions")
  // ✅ NOVO
  customerPackages CustomerPackage[]

  // ✅ B1: Índice composto [barbershopId, active]
  // Substitui [barbershopId] simples — leftmost prefix cobre queries sem active
  // Cobre: { barbershopId } → listagem geral e IDOR fix
  // Cobre: { barbershopId, active: true } → dashboard count, analytics allCustomers
  @@index([barbershopId, active])
  @@map("customers")
}

model Client {
  id         String    @id @default(uuid())
  name       String
  email      String    @unique
  phone      String?
  password   String?
  avatar     String?
  birthDate  DateTime?
  active     Boolean   @default(true)
  googleId   String?   @unique
  facebookId String?   @unique
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  resetPasswordToken   String?   @unique
  resetPasswordExpires DateTime?

  termsAccepted      Boolean   @default(false)
  termsAcceptedAt    DateTime?
  privacyAccepted    Boolean   @default(false)
  privacyAcceptedAt  DateTime?
  termsVersion       String?
  privacyVersion     String?

  nameChangedAt   DateTime?
  phoneOtp        String?
  phoneOtpExpires DateTime?
  phoneVerified   Boolean   @default(false)

  appointments     Appointment[]
  favorites        ClientFavorite[]
  // ✅ NOVO
  customerPackages CustomerPackage[]

  @@map("clients")
}

model Appointment {
  id        String   @id @default(uuid())
  date      DateTime
  status    String   @default("scheduled")
  notes     String?
  price     Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  barbershop   Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  barbershopId String

  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerId String?

  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  clientId String?

  barber   User   @relation(fields: [barberId], references: [id], onDelete: Cascade)
  barberId String

  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  serviceId String

  // ✅ NOVO — vínculo com uso de pacote
  packageUsages PackageUsage[]

  // ✅ B1: 3 índices compostos para o modelo mais consultado do sistema

  // [barbershopId, date] — índice mais importante do schema
  // Substitui [barbershopId] simples via prefixo esquerdo
  // Cobre: dashboard stats/charts, Finance cashflow, Finance summary,
  //        reminder job (date range amanhã), reports com filtro de data
  @@index([barbershopId, date])

  // [barbershopId, status]
  // Cobre queries SEM filtro de date: topServices groupBy { barbershopId, status: 'completed' },
  // analytics conversionFunnel, reminder job { status: { in: ['scheduled', 'confirmed'] } }
  @@index([barbershopId, status])

  // [barbershopId, barberId]
  // Cobre: reports por barbeiro, analytics barber performance,
  //        commissions calculate (appointments por barbeiro no mês)
  @@index([barbershopId, barberId])

  @@map("appointments")
}

model ClientFavorite {
  id           String   @id @default(uuid())
  clientId     String
  barbershopId String
  createdAt    DateTime @default(now())

  client     Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  barbershop Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)

  @@unique([clientId, barbershopId])
  @@map("client_favorites")
}

// ═══════════════════════════════════════════════════════
// ✅ NOVO: Controle de Estoque
// ═══════════════════════════════════════════════════════

model StockItem {
  id           String   @id @default(uuid())
  barbershopId String
  name         String
  category     String   @default("product") // product, supply, equipment, other
  quantity     Int      @default(0)
  minQuantity  Int      @default(5)          // threshold para alerta de estoque baixo
  unit         String   @default("un")       // un, ml, l, g, kg, cx
  costPrice    Decimal? @db.Decimal(10, 2)
  salePrice    Decimal? @db.Decimal(10, 2)
  supplier     String?
  notes        String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  barbershop Barbershop      @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  movements  StockMovement[]

  // ✅ B1: Índice simples [barbershopId]
  // Cobre: GET /stock listagem, findFirst (IDOR fix), low-stock check
  @@index([barbershopId])
  @@map("stock_items")
}

model StockMovement {
  id          String   @id @default(uuid())
  stockItemId String
  type        String   // 'in', 'out', 'adjustment'
  quantity    Int
  reason      String?
  unitPrice   Decimal? @db.Decimal(10, 2)  // preço de venda unitário (preenchido em 'out')
  barberId    String?  // barbeiro que realizou a venda
  customerId  String?  // cliente que comprou (opcional)
  createdAt   DateTime @default(now())

  stockItem StockItem @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
  barber    User?     @relation("BarberStockMovements", fields: [barberId], references: [id], onDelete: SetNull)

  // ✅ B1: Índice simples [stockItemId]
  // Cobre: GET /stock/:id/movements (findMany por stockItemId)
  @@index([stockItemId])
  @@map("stock_movements")
}

// ═══════════════════════════════════════════════════════
// ✅ NOVO: Pacotes de Clientes (ex: 4 cortes)
// ═══════════════════════════════════════════════════════

model CustomerPackage {
  id             String    @id @default(uuid())
  barbershopId   String
  customerId     String?   // cliente cadastrado pelo barbeiro
  clientId       String?   // cliente com conta própria (app)
  name           String                          // ex: "Pacote 4 Cortes"
  description    String?
  totalCuts      Int                             // total de cortes/sessões do pacote
  usedCuts       Int       @default(0)           // quantos já foram utilizados
  price          Decimal   @db.Decimal(10, 2)   // valor pago pelo pacote
  startDate      DateTime
  expirationDate DateTime
  lastCutAt      DateTime?
  status         String    @default("active")   // active, expired, completed, cancelled
  includedServices Json?                         // lista de serviços inclusos (JSON array)
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  barbershop Barbershop    @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  customer   Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  client     Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  usages     PackageUsage[]

  // ✅ B1: Índice simples [barbershopId]
  // Cobre: GET /packages listagem por barbearia
  @@index([barbershopId])
  @@map("customer_packages")
}

model PackageUsage {
  id            String    @id @default(uuid())
  packageId     String
  appointmentId String?
  usedAt        DateTime  @default(now())
  notes         String?
  barberId      String?
  barber        User?     @relation("BarberPackageUsages", fields: [barberId], references: [id], onDelete: SetNull)

  package     CustomerPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  appointment Appointment?    @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@map("package_usages")
}
